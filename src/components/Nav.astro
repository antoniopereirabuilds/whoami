---
import { profile } from '~/data/profile';
import ThemeToggle from './ThemeToggle.astro';

const items = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#clients', label: 'Clients' },
  { href: '#writing', label: 'Writing' },
  { href: '#endorsements', label: 'Endorsements' },
  { href: '#faq', label: 'FAQ' },
];
---

<header
  class="sticky top-0 z-50 border-b border-transparent backdrop-blur-md transition-colors duration-300"
  id="site-nav"
>
  <div class="container-page flex h-16 items-center justify-between">
    <a href="#top" class="group flex items-center gap-2.5">
      <span
        class="display flex h-9 w-9 items-center justify-center rounded-xl bg-ink-900 text-sm font-bold text-white transition-all duration-300 group-hover:bg-brand-600 group-hover:rotate-3 dark:bg-white dark:text-ink-900 dark:group-hover:bg-brand-500 dark:group-hover:text-white"
        aria-hidden="true"
      >
        {profile.initials}
      </span>
      <span class="hidden text-sm font-semibold tracking-tight sm:inline-block">
        {profile.name}
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {items.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-3 py-1.5 text-sm font-medium text-ink-600 transition-colors hover:bg-ink-100 hover:text-ink-900 dark:text-ink-300 dark:hover:bg-ink-800 dark:hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      <a href="#contact" class="btn-primary hidden sm:inline-flex">
        Get in touch
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 8) {
        nav.classList.add('bg-white/80', 'dark:bg-ink-950/80', 'border-ink-200/70', 'dark:border-ink-800/70');
      } else {
        nav.classList.remove('bg-white/80', 'dark:bg-ink-950/80', 'border-ink-200/70', 'dark:border-ink-800/70');
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
