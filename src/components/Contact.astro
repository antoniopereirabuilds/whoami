---
import { Icon } from 'astro-icon/components';
import { profile } from '~/data/profile';
---

<section id="contact" class="section relative">
  <div class="container-page">
    <div class="reveal relative overflow-hidden rounded-3xl border border-ink-200 bg-ink-950 px-8 py-16 text-white sm:px-12 md:px-16 dark:border-ink-800">
      <!-- Background art -->
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-brand-600/40 blur-3xl"></div>
        <div class="absolute -right-10 bottom-0 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute inset-0 bg-grid-dark bg-[size:40px_40px] opacity-25 [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_75%)]"></div>
      </div>

      <div class="relative grid gap-10 md:grid-cols-[1.2fr_1fr] md:items-center">
        <div>
          <span class="eyebrow text-brand-300">Contact</span>
          <h2 class="display mt-3 text-4xl font-semibold leading-tight sm:text-5xl">
            Have a problem worth solving?
          </h2>
          <p class="mt-5 max-w-xl text-lg text-white/80">
            I'm exploring senior architect and engineering leadership roles. If you're building something ambitious — especially on OutSystems — let's talk.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={`mailto:${profile.email}?subject=Opportunity%20for%20Ant%C3%B3nio`}
              class="btn bg-white text-ink-900 hover:bg-accent hover:text-ink-900 hover:-translate-y-0.5"
            >
              <Icon name="lucide:mail" class="h-4 w-4" />
              {profile.email}
            </a>
            <a
              href={profile.linkedin}
              target="_blank"
              rel="noopener"
              class="btn border border-white/30 text-white hover:border-accent hover:text-accent"
            >
              <Icon name="simple-icons:linkedin" class="h-4 w-4" />
              Message on LinkedIn
            </a>
            <a
              href={profile.outsystems}
              target="_blank"
              rel="noopener"
              class="btn border border-white/30 text-white hover:border-accent hover:text-accent"
            >
              <Icon name="lucide:award" class="h-4 w-4" />
              OutSystems profile
            </a>
          </div>
        </div>

        <ul class="grid grid-cols-1 gap-3 text-sm sm:grid-cols-2 md:grid-cols-1">
          <li class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur">
            <Icon name="lucide:map-pin" class="h-4 w-4 text-brand-300" />
            <span>{profile.location}</span>
          </li>
          <li class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur">
            <Icon name="lucide:globe" class="h-4 w-4 text-brand-300" />
            <span>Open to remote across EU & UK</span>
          </li>
          <li class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur">
            <Icon name="lucide:clock" class="h-4 w-4 text-brand-300" />
            <span>Usually responds within 24h</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
