---
import { Icon } from 'astro-icon/components';
import { experience } from '~/data/profile';
---

<section id="experience" class="section relative">
  <div class="container-page">
    <div class="reveal max-w-3xl">
      <span class="eyebrow">Experience</span>
      <h2 class="section-title mt-3">A decade close to the OutSystems platform.</h2>
      <p class="mt-5 text-lg text-ink-600 dark:text-ink-300">
        From R&D engineer at OutSystems to architect for enterprise clients — every step has been about the same craft, just from different angles.
      </p>
    </div>

    <ol class="reveal mt-14 relative space-y-6 border-l border-ink-200 pl-6 dark:border-ink-800 sm:pl-10">
      {experience.map((job, idx) => (
        <li class="relative group">
          <span
            class={`absolute -left-[33px] top-6 h-3 w-3 rounded-full ring-4 sm:-left-[45px] ${
              job.current
                ? 'bg-brand-500 ring-brand-100 dark:ring-brand-950'
                : 'bg-ink-300 ring-white dark:bg-ink-700 dark:ring-ink-950'
            }`}
            aria-hidden="true"
          ></span>

          <article class="surface p-6 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:border-brand-500/50 group-hover:shadow-soft sm:p-8 dark:group-hover:border-brand-400/40">
            <header class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <h3 class="display text-xl font-semibold text-ink-900 dark:text-ink-50">
                  {job.role}
                </h3>
                <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
                  <span class="font-semibold text-brand-700 dark:text-brand-300">{job.company}</span>
                  {job.via && (
                    <>
                      <span class="text-ink-400">·</span>
                      <span class="italic text-ink-500 dark:text-ink-400">via {job.via}</span>
                    </>
                  )}
                  {job.client && (
                    <>
                      <span class="text-ink-400">·</span>
                      <span class="font-medium text-ink-900 dark:text-ink-100">{job.client}</span>
                    </>
                  )}
                  {job.location && (
                    <>
                      <span class="text-ink-400">·</span>
                      <span class="text-ink-600 dark:text-ink-400">{job.location}</span>
                    </>
                  )}
                </div>
                {(job.clientIndustry || job.clientDescription) && (
                  <p class="mt-2 text-sm text-ink-600 dark:text-ink-400">
                    {job.clientIndustry && (
                      <span class="mr-2 inline-flex items-center rounded-full bg-brand-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-brand-700 dark:bg-brand-950/40 dark:text-brand-300">
                        {job.clientIndustry}
                      </span>
                    )}
                    {job.clientDescription}
                  </p>
                )}
                {job.project && (
                  <p class="mt-2 text-sm italic text-ink-600 dark:text-ink-400">{job.project}</p>
                )}
              </div>
              <span class={`pill ${job.current ? 'border-brand-500/50 bg-brand-50 text-brand-700 dark:bg-brand-950/50 dark:text-brand-200' : ''}`}>
                {job.current && <Icon name="lucide:circle-dot" class="h-3.5 w-3.5" />}
                {job.period}
              </span>
            </header>

            <ul class="mt-5 space-y-2.5">
              {job.highlights.map((h) => (
                <li class="flex items-start gap-3 text-[15px] leading-relaxed text-ink-700 dark:text-ink-300">
                  <Icon name="lucide:check" class="mt-1 h-4 w-4 flex-shrink-0 text-brand-600 dark:text-brand-400" />
                  <span>{h}</span>
                </li>
              ))}
            </ul>

            {job.technologies && job.technologies.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {job.technologies.map((t) => (
                  <span class="inline-flex items-center rounded-full border border-ink-200 bg-ink-50 px-2.5 py-0.5 text-xs font-medium text-ink-700 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-200">
                    {t}
                  </span>
                ))}
              </div>
            )}

            {job.liveUrl && (
              <a
                href={job.liveUrl}
                target="_blank"
                rel="noopener"
                class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 hover:text-brand-600 dark:text-brand-300 dark:hover:text-brand-200"
              >
                <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
                View live →
              </a>
            )}
          </article>
        </li>
      ))}
    </ol>
  </div>
</section>
