---
import { Icon } from 'astro-icon/components';
import { recommendations } from '~/data/profile';

const formatDate = (iso?: string) => {
  if (!iso) return null;
  const [year, month] = iso.split('-');
  if (!month) return year;
  const monthNames = [
    'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
    'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
  ];
  return `${monthNames[parseInt(month, 10) - 1]} ${year}`;
};
---

{recommendations.length > 0 && (
  <section id="endorsements" class="section relative bg-ink-50/60 dark:bg-ink-900/30">
    <div class="container-page">
      <div class="reveal max-w-3xl">
        <span class="eyebrow">Endorsements</span>
        <h2 class="section-title mt-3">What people say.</h2>
        <p class="mt-5 text-lg text-ink-600 dark:text-ink-300">
          Selected from LinkedIn recommendations — managers, direct reports, and peers I've shipped real work with.
        </p>
      </div>

      <div class="reveal mt-12 grid gap-5 md:grid-cols-2">
        {recommendations.map((r) => (
          <figure class="surface relative flex flex-col gap-5 p-7">
            <Icon
              name="lucide:quote"
              class="absolute right-5 top-5 h-6 w-6 text-brand-500/20 dark:text-brand-400/20"
              aria-hidden="true"
            />
            <blockquote class="space-y-3 text-[15px] leading-relaxed text-ink-700 dark:text-ink-300">
              {r.text.split(/\n\s*\n/).filter(Boolean).map((para) => (
                <p>{para.trim()}</p>
              ))}
            </blockquote>
            <figcaption class="mt-auto border-t border-ink-200 pt-4 dark:border-ink-800">
              <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
                <div>
                  {r.url ? (
                    <a
                      href={r.url}
                      target="_blank"
                      rel="noopener"
                      class="display text-sm font-semibold text-ink-900 transition-colors hover:text-brand-700 dark:text-ink-50 dark:hover:text-brand-300"
                    >
                      {r.name}
                    </a>
                  ) : (
                    <span class="display text-sm font-semibold text-ink-900 dark:text-ink-50">
                      {r.name}
                    </span>
                  )}
                  {(r.role || r.company) && (
                    <div class="text-xs text-ink-600 dark:text-ink-400">
                      {r.role}{r.role && r.company ? ' · ' : ''}{r.company}
                    </div>
                  )}
                </div>
                {formatDate(r.date) && (
                  <span class="text-[11px] uppercase tracking-wider text-ink-500 dark:text-ink-400">
                    {formatDate(r.date)}
                  </span>
                )}
              </div>
              {r.relationship && (
                <div class="mt-1.5 text-[11px] uppercase tracking-wider text-brand-700 dark:text-brand-300">
                  {r.relationship}
                </div>
              )}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}
