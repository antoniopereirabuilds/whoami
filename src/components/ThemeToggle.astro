---
import { Icon } from 'astro-icon/components';
---

<button
  type="button"
  id="theme-toggle"
  class="grid h-9 w-9 place-items-center rounded-full border border-ink-200 text-ink-700 transition-colors hover:border-brand-500 hover:text-brand-600 dark:border-ink-700 dark:text-ink-200 dark:hover:border-brand-400 dark:hover:text-brand-300"
  aria-label="Toggle dark mode"
>
  <Icon name="lucide:sun" class="h-4 w-4 dark:hidden" />
  <Icon name="lucide:moon" class="hidden h-4 w-4 dark:block" />
</button>

<script is:inline>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle('dark');
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (e) {}
    });
  }
</script>
