---
import { Icon } from 'astro-icon/components';
import { profile } from '~/data/profile';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<section id="top" class="relative overflow-hidden pt-12 sm:pt-16">
  <!-- Decorative backdrop -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute -top-32 left-1/2 h-[36rem] w-[60rem] -translate-x-1/2 rounded-full bg-gradient-to-br from-brand-500/30 via-brand-400/10 to-transparent blur-3xl dark:from-brand-500/25"
    >
    </div>
    <div
      class="absolute inset-0 bg-grid-light bg-[size:48px_48px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)] dark:bg-grid-dark"
    >
    </div>
  </div>

  <div class="container-page section pt-10 sm:pt-16">
    <div class="grid items-center gap-12 lg:grid-cols-[1.4fr_1fr] lg:gap-16">
      <!-- Text column -->
      <div class="reveal flex flex-col items-start gap-6">
        <div class="flex flex-wrap items-center gap-2">
          <a
            href={profile.outsystems}
            target="_blank"
            rel="noopener"
            class="pill border-brand-500/40 bg-brand-50 text-brand-700 transition-colors hover:border-brand-500 hover:bg-brand-100 dark:bg-brand-950/40 dark:text-brand-200 dark:hover:bg-brand-900/60"
          >
            <Icon name="lucide:award" class="h-3.5 w-3.5" />
            OutSystems Champion · Since 2021
          </a>
          <span class="pill">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
            </span>
            {profile.availability}
          </span>
          <span class="pill">
            <Icon name="lucide:map-pin" class="h-3.5 w-3.5" />
            {profile.location}
          </span>
        </div>

        <h1 class="display max-w-3xl text-5xl font-semibold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
          <span class="block text-ink-900 dark:text-ink-50">{profile.name}.</span>
          <span class="block gradient-text">
            {profile.headline}.
          </span>
        </h1>

        <p class="max-w-2xl text-lg leading-relaxed text-ink-600 dark:text-ink-300 sm:text-xl">
          {profile.subheadline}
        </p>

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <a href="#contact" class="btn-primary">
            <Icon name="lucide:mail" class="h-4 w-4" />
            Let's talk
          </a>
          <a href={`${base}${profile.resumeUrl}`} class="btn-ghost" download>
            <Icon name="lucide:file-down" class="h-4 w-4" />
            Download CV
          </a>
          <a href={profile.linkedin} target="_blank" rel="noopener" class="btn-ghost">
            <Icon name="simple-icons:linkedin" class="h-4 w-4" />
            LinkedIn
          </a>
          <a href="#experience" class="btn-ghost">
            <Icon name="lucide:arrow-down" class="h-4 w-4" />
            See experience
          </a>
        </div>
      </div>

      <!-- Portrait column -->
      <div class="reveal relative mx-auto flex w-full max-w-md justify-center lg:max-w-none lg:justify-end">
        <div class="relative">
          <!-- Decorative glows -->
          <div class="pointer-events-none absolute -inset-6 -z-10 rounded-[2rem] bg-gradient-to-tr from-brand-500/40 via-brand-400/0 to-accent/30 blur-2xl"></div>
          <!-- Frame -->
          <div class="relative aspect-square w-[280px] overflow-hidden rounded-[2rem] border border-ink-200 bg-ink-100 shadow-soft sm:w-[340px] lg:w-[380px] xl:w-[420px] dark:border-ink-800 dark:bg-ink-900">
            <img
              src={`${base}${profile.photoUrl}`}
              alt={`${profile.name} — ${profile.headline}`}
              width="800"
              height="800"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="h-full w-full object-cover"
            />
            <!-- Soft gradient overlay for legibility of badge -->
            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-ink-950/70 via-ink-950/20 to-transparent"></div>
            <!-- Floating signature badge -->
            <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between gap-3 rounded-2xl border border-white/10 bg-ink-950/60 px-3 py-2 text-white backdrop-blur">
              <div class="flex items-center gap-2">
                <Icon name="lucide:award" class="h-4 w-4 text-accent" />
                <span class="text-xs font-semibold uppercase tracking-wider">
                  OutSystems Champion
                </span>
              </div>
              <span class="display text-[10px] font-bold uppercase tracking-[0.18em] text-accent">
                '21
              </span>
            </div>
          </div>
          <!-- Floating Forge chip -->
          <div class="absolute -bottom-3 -right-3 hidden rotate-3 rounded-2xl border border-ink-200 bg-white px-3 py-2 shadow-soft sm:flex sm:items-center sm:gap-2 dark:border-ink-700 dark:bg-ink-900">
            <Icon name="lucide:package" class="h-4 w-4 text-brand-600 dark:text-brand-400" />
            <div class="leading-tight">
              <div class="display text-sm font-semibold text-ink-900 dark:text-ink-50">50+</div>
              <div class="text-[10px] uppercase tracking-wider text-ink-500 dark:text-ink-400">Forge assets</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Metrics strip -->
    <div class="reveal mt-16 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-ink-200 bg-ink-200 sm:grid-cols-4 dark:border-ink-800 dark:bg-ink-800">
      {profile.metrics.map((m) => (
        <div class="group flex flex-col gap-1 bg-white p-5 transition-colors hover:bg-brand-50 dark:bg-ink-950 dark:hover:bg-brand-950/30">
          <div class="display text-2xl font-semibold text-ink-900 transition-colors group-hover:text-brand-700 sm:text-3xl dark:text-ink-50 dark:group-hover:text-brand-300">
            {m.value}
          </div>
          <div class="text-xs font-medium uppercase tracking-wider text-ink-500 dark:text-ink-400">
            {m.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Quote -->
    <figure class="reveal mt-16 max-w-3xl">
      <blockquote class="display text-xl font-medium leading-snug text-ink-700 sm:text-2xl dark:text-ink-200">
        <span class="text-brand-500">"</span>{profile.quote}<span class="text-brand-500">"</span>
      </blockquote>
      <figcaption class="mt-3 text-sm uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">
        — How I think about software
      </figcaption>
    </figure>
  </div>
</section>
