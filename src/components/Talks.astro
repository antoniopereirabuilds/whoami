---
import { Icon } from 'astro-icon/components';
import { talks } from '~/data/profile';

const today = new Date();

const formatLongDate = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
};

const statusFor = (iso: string): { label: string; tone: 'upcoming' | 'recent' | 'past' } | null => {
  const d = new Date(iso);
  const diffDays = Math.floor((d.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
  if (diffDays > 0) return { label: 'Upcoming', tone: 'upcoming' };
  if (diffDays >= -90) return { label: 'Recent', tone: 'recent' };
  return null;
};
---

{talks.length > 0 && (
  <section id="talks" class="section relative">
    <div class="container-page">
      <div class="reveal flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <span class="eyebrow">Talks</span>
          <h2 class="section-title mt-3">Sharing the craft.</h2>
          <p class="mt-5 text-lg text-ink-600 dark:text-ink-300">
            Community sessions, meetups, and conferences — the OutSystems ecosystem grows when we trade lessons in the open.
          </p>
        </div>
      </div>

      <div class="reveal mt-12 grid gap-5 md:grid-cols-2">
        {talks.map((t) => {
          const status = statusFor(t.date);
          return (
            <article class="surface group relative flex flex-col gap-4 p-7 transition-all duration-300 hover:-translate-y-1 hover:border-brand-500/60 hover:shadow-soft dark:hover:border-brand-400/40">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <span class="eyebrow">Meetup</span>
                {status && (
                  <span
                    class={`inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${
                      status.tone === 'upcoming'
                        ? 'bg-brand-100 text-brand-700 dark:bg-brand-950/40 dark:text-brand-300'
                        : 'bg-emerald-100 text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-300'
                    }`}
                  >
                    {status.tone === 'upcoming' && (
                      <span class="relative flex h-1.5 w-1.5">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-current opacity-75"></span>
                        <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-current"></span>
                      </span>
                    )}
                    {status.label}
                  </span>
                )}
              </div>

              <h3 class="display text-xl font-semibold leading-snug text-ink-900 dark:text-ink-50">
                {t.title}
              </h3>

              <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-ink-600 dark:text-ink-400">
                <span class="font-semibold text-brand-700 dark:text-brand-300">{formatLongDate(t.date)}</span>
                {t.venue && (
                  <>
                    <span class="text-ink-400">·</span>
                    <span>{t.venue}</span>
                  </>
                )}
                {t.partnership && (
                  <>
                    <span class="text-ink-400">·</span>
                    <span class="italic">{t.partnership}</span>
                  </>
                )}
              </div>

              {t.coSpeaker && (
                <div class="flex items-center gap-2 text-sm text-ink-700 dark:text-ink-300">
                  <Icon name="lucide:users" class="h-4 w-4 text-brand-600 dark:text-brand-400" />
                  <span>with <span class="font-semibold">{t.coSpeaker}</span></span>
                </div>
              )}

              {t.description && (
                <p class="text-sm leading-relaxed text-ink-600 dark:text-ink-300">{t.description}</p>
              )}

              {t.url && (
                <a
                  href={t.url}
                  target="_blank"
                  rel="noopener"
                  class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 dark:text-brand-300"
                >
                  Event details
                  <Icon name="lucide:arrow-up-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
                </a>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </section>
)}
