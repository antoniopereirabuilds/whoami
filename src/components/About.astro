---
import { about, principles } from '~/data/profile';
---

<section id="about" class="section relative">
  <div class="container-page">
    <div class="reveal grid gap-12 md:grid-cols-[1fr_1.4fr] md:gap-16">
      <div>
        <span class="eyebrow">About</span>
        <h2 class="section-title mt-3">Senior engineer who ships, leads, and teaches.</h2>
      </div>
      <div class="space-y-5 text-lg leading-relaxed text-ink-700 dark:text-ink-300">
        {about.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <div class="reveal mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {principles.map((p, i) => (
        <article class="surface group relative overflow-hidden p-6 transition-all duration-300 hover:-translate-y-1 hover:border-brand-500/60 hover:shadow-soft dark:hover:border-brand-400/40">
          <div class="display absolute right-5 top-4 text-xs font-bold text-ink-300 dark:text-ink-700">
            0{i + 1}
          </div>
          <h3 class="display text-lg font-semibold text-ink-900 dark:text-ink-50">
            {p.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600 dark:text-ink-300">
            {p.body}
          </p>
          <div class="mt-5 h-px w-10 bg-brand-500 transition-all duration-300 group-hover:w-20"></div>
        </article>
      ))}
    </div>
  </div>
</section>
