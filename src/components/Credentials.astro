---
import { Icon } from 'astro-icon/components';
import {
  certifications,
  specializations,
  commercialCredentials,
  honors,
  education,
  profile,
  type Credential,
} from '~/data/profile';

const groups: Array<{
  title: string;
  count: number;
  icon: string;
  blurb: string;
  items: Credential[];
}> = [
  {
    title: 'Certifications',
    count: certifications.length,
    icon: 'lucide:badge-check',
    blurb: 'Platform proficiency across both OutSystems generations.',
    items: certifications,
  },
  {
    title: 'Specializations',
    count: specializations.length,
    icon: 'lucide:gem',
    blurb: 'Top-tier credentials reserved for advanced practitioners.',
    items: specializations,
  },
];

const platformLabel: Record<Credential['platform'], string> = {
  ODC: 'OutSystems Developer Cloud',
  O11: 'OutSystems 11',
};
---

<section id="credentials" class="section relative">
  <div class="container-page">
    <div class="reveal max-w-3xl">
      <span class="eyebrow">Credentials</span>
      <h2 class="section-title mt-3">Certified, recognized, and trained at the source.</h2>
      <p class="mt-5 text-lg text-ink-600 dark:text-ink-300">
        Ten active OutSystems credentials spanning Developer Cloud (ODC), OutSystems 11, and commercial enablement — verified on my official profile.
      </p>
    </div>

    <!-- Champion (full width, hero-of-section) -->
    <article class="reveal mt-12 relative overflow-hidden rounded-2xl border border-brand-500/40 bg-gradient-to-br from-brand-600 via-brand-700 to-ink-900 p-8 text-white shadow-glow sm:p-10">
      <div class="pointer-events-none absolute -right-12 -top-12 h-56 w-56 rounded-full bg-accent/30 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 bg-grid-dark bg-[size:32px_32px] opacity-30"></div>
      <div class="relative grid gap-8 md:grid-cols-[1.4fr_1fr] md:items-end">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider backdrop-blur">
            <Icon name="lucide:trophy" class="h-3.5 w-3.5" />
            Honor
          </span>
          {honors.map((h) => (
            <>
              <div class="mt-5 flex flex-wrap items-baseline gap-x-4 gap-y-1">
                <h3 class="display text-3xl font-semibold sm:text-4xl">{h.name}</h3>
                <span class="display text-sm font-semibold uppercase tracking-[0.18em] text-accent">
                  Since {h.since}
                </span>
              </div>
              <p class="mt-3 max-w-xl text-white/80">{h.description}</p>
              <div class="mt-6 flex flex-wrap gap-3">
                <a
                  href={profile.outsystems}
                  target="_blank"
                  rel="noopener"
                  class="btn bg-white text-ink-900 hover:bg-accent hover:text-ink-900 hover:-translate-y-0.5"
                >
                  <Icon name="lucide:external-link" class="h-4 w-4" />
                  View OutSystems profile
                </a>
                <a
                  href={`${profile.outsystems}forge/`}
                  target="_blank"
                  rel="noopener"
                  class="btn border border-white/30 text-white hover:border-accent hover:text-accent"
                >
                  <Icon name="lucide:package" class="h-4 w-4" />
                  50+ Forge assets
                </a>
              </div>
            </>
          ))}
        </div>

        <!-- Quick stats -->
        <dl class="grid grid-cols-3 gap-px overflow-hidden rounded-xl border border-white/15 bg-white/10 text-center md:max-w-sm md:justify-self-end">
          <div class="bg-ink-950/40 px-3 py-4 backdrop-blur">
            <dt class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Champion</dt>
            <dd class="display mt-1 text-xl font-semibold">2021</dd>
          </div>
          <div class="bg-ink-950/40 px-3 py-4 backdrop-blur">
            <dt class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Forge</dt>
            <dd class="display mt-1 text-xl font-semibold">50+</dd>
          </div>
          <div class="bg-ink-950/40 px-3 py-4 backdrop-blur">
            <dt class="text-[10px] font-semibold uppercase tracking-wider text-white/60">Credentials</dt>
            <dd class="display mt-1 text-xl font-semibold">10</dd>
          </div>
        </dl>
      </div>
    </article>

    <!-- Certifications + Specializations -->
    <div class="reveal mt-6 grid gap-6 md:grid-cols-2">
      {groups.map((g) => (
        <article class="surface flex flex-col p-7">
          <header class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-xl bg-brand-600 text-white dark:bg-brand-500">
                <Icon name={g.icon} class="h-4 w-4" />
              </span>
              <div>
                <h3 class="display text-lg font-semibold">{g.title}</h3>
                <p class="text-xs text-ink-500 dark:text-ink-400">{g.blurb}</p>
              </div>
            </div>
            <span class="display rounded-full bg-ink-100 px-3 py-1 text-sm font-semibold text-ink-900 dark:bg-ink-800 dark:text-ink-50">
              {g.count}
            </span>
          </header>

          <ul class="mt-5 divide-y divide-ink-200 dark:divide-ink-800">
            {g.items.map((c) => (
              <li class="flex items-center justify-between gap-3 py-3.5 text-sm">
                <div class="flex min-w-0 items-start gap-2.5">
                  {c.highlight ? (
                    <Icon name="lucide:star" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-500" />
                  ) : (
                    <Icon name="lucide:check-circle-2" class="mt-0.5 h-4 w-4 flex-shrink-0 text-ink-400" />
                  )}
                  <div class="min-w-0">
                    <div class={`truncate ${c.highlight ? 'font-semibold text-ink-900 dark:text-ink-50' : 'text-ink-800 dark:text-ink-100'}`}>
                      {c.name}
                    </div>
                    <div class="mt-0.5 flex items-center gap-2 text-xs text-ink-500 dark:text-ink-400">
                      <span
                        class={`inline-flex items-center rounded-md px-1.5 py-0.5 text-[10px] font-bold tracking-wider ${
                          c.platform === 'ODC'
                            ? 'bg-brand-100 text-brand-800 dark:bg-brand-900/60 dark:text-brand-200'
                            : 'bg-ink-100 text-ink-700 dark:bg-ink-800 dark:text-ink-200'
                        }`}
                        title={platformLabel[c.platform]}
                      >
                        {c.platform}
                      </span>
                      <span>· {c.date}</span>
                    </div>
                  </div>
                </div>
              </li>
            ))}
          </ul>

          <a
            href={profile.outsystems}
            target="_blank"
            rel="noopener"
            class="mt-5 inline-flex items-center gap-1.5 text-xs font-semibold text-brand-700 hover:text-brand-900 dark:text-brand-300 dark:hover:text-brand-100"
          >
            Verify on OutSystems
            <Icon name="lucide:arrow-up-right" class="h-3.5 w-3.5" />
          </a>
        </article>
      ))}
    </div>

    <!-- Commercial enablement -->
    <div class="reveal mt-6 surface flex flex-wrap items-center justify-between gap-4 p-6">
      <div class="flex items-center gap-3">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-ink-900 text-white dark:bg-white dark:text-ink-900">
          <Icon name="lucide:briefcase" class="h-4 w-4" />
        </span>
        <div>
          <h3 class="display text-base font-semibold">Commercial enablement</h3>
          <p class="text-xs text-ink-500 dark:text-ink-400">
            Trained to scope and qualify OutSystems opportunities alongside delivery.
          </p>
        </div>
      </div>
      <ul class="flex flex-wrap gap-2">
        {commercialCredentials.map((c) => (
          <li class="pill">
            <Icon name="lucide:check-circle-2" class="h-3.5 w-3.5 text-brand-500" />
            {c.name}
          </li>
        ))}
      </ul>
    </div>

    <!-- Education -->
    <div class="reveal mt-10 grid gap-4 md:grid-cols-2">
      {education.map((e) => (
        <article class="surface p-6">
          <div class="flex items-center gap-3">
            <Icon name="lucide:graduation-cap" class="h-5 w-5 text-brand-600 dark:text-brand-400" />
            <span class="text-xs uppercase tracking-wider text-ink-500">{e.period}</span>
          </div>
          <h3 class="display mt-3 text-lg font-semibold text-ink-900 dark:text-ink-50">
            {e.degree}
          </h3>
          <p class="mt-1 text-sm font-medium text-brand-700 dark:text-brand-300">{e.school}</p>
          {e.detail && <p class="mt-2 text-sm text-ink-600 dark:text-ink-300">{e.detail}</p>}
        </article>
      ))}
    </div>
  </div>
</section>
